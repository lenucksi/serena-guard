{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": { "recommended": true }
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded",
			"trailingCommas": "all"
		}
	},
	"files": {
		"includes": ["**/*.ts", "**/*.js", "**/*.json", "!**/node_modules/", "!**/*.js"]
	}
}
